# ─── Logs ────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log
pip-log.txt
pip-delete-this-directory.txt

# ─── Python ──────────────────────────────────────────────
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/
**/*.egg-info/
**/dist/
**/build/
**/.tox/

# ─── Node / Vite / Frontend ──────────────────────────────
**/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.turbo/

# ─── Environment variables ───────────────────────────────
# Ignore every .env and .env.<name>, but always allow *.example templates
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# ─── Editor / OS ─────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ─── Project intermediates / temp ────────────────────────
.tmp/
nul
*.csv
dataset_*.json
EXECUTE_*.sql

# ─── Playwright / test artifacts (MCP traces, screenshots) ─
.playwright-mcp/
screenshots/
test-results/
playwright-report/

# ─── Railway ─────────────────────────────────────────────
.railway/

# ─── Supabase CLI / local state ──────────────────────────
supabase/.temp/
supabase/.branches/

# ─── Auto Claude framework (legacy, kept for back-compat) ─
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.security-key

# ─── Runtime secrets backups (never commit) ──────────────
.tmp/legacy-secrets/
docker-compose.local.yml
