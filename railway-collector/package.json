{
  "name": "railway-collector",
  "version": "1.0.0",
  "description": "Sistema de coleta automatizada de reviews via Railway",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate:synthetic-reviews": "node scripts/generate-synthetic-reviews.js",
    "start:cron": "ENABLE_CRON=true node server.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "node-cron": "^3.0.3",
    "@supabase/supabase-js": "^2.39.0",
    "apify-client": "^2.7.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "supertest": "7.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "apify",
    "supabase",
    "reviews",
    "automation",
    "railway"
  ],
  "author": "Cartório Paulista",
  "license": "MIT"
}
