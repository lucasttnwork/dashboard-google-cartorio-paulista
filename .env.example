# Root-level .env.example (Dashboard Cartório Paulista)
# --------------------------------------------------------------
# This file documents repo-wide variables. Each service has its own
# .env.example that is the canonical source for its own variables:
#
#   - backend/.env.example
#   - frontend/.env.example
#   - workers/.env.example
#
# Copy each to <service>/.env.local before running `docker compose
# -f docker-compose.dev.yml up --build`.

# --------------------------------------------------------------
# Supabase Management API access token (sbp_*)
# Used by the Supabase CLI and by operator scripts that need to
# query the Management API directly (e.g. applying migrations).
# DO NOT commit your real token. This variable stays on the
# operator's machine (e.g. via direnv) — it is NOT passed to any
# running container.
# --------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=<paste_sbp_token_here_locally>

# --------------------------------------------------------------
# Supabase project reference (stable, safe to share)
# --------------------------------------------------------------
SUPABASE_PROJECT_REF=bugpetfkyoraidyxmzxu
